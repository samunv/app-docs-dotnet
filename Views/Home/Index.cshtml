@{
    ViewData["Title"] = "Editor de texto";
}

@section Scripts {
    <script type="module" src="~/js/home.js"></script>
}

@section Styles {
    <link rel="stylesheet" href="~/css/home.css" />
}

<div>

    <!-- Barra de herramientas -->
    <div class="toolbar">
        <button onclick="formato('bold')" title="Negrita"><b>B</b></button>
        <button onclick="formato('italic')" title="Cursiva"><i>I</i></button>
        <button onclick="formato('underline')" title="Subrayado"><u>U</u></button>
        <select id="selectTamano"
                onmousedown="this.focus()"
                onchange="cambiarTamano(this.value); this.blur()">
            <option value="">Tamaño</option>
            <option value="10">10</option>
            <option value="12">12</option>
            <option value="14">14</option>
            <option value="16">16</option>
            <option value="18">18</option>
            <option value="20">20</option>
            <option value="24">24</option>
            <option value="28">28</option>
            <option value="32">32</option>
            <option value="48">48</option>
            <option value="72">72</option>
        </select>

        <div class="separador"></div>

        <button onclick="formato('justifyLeft')" title="Alinear izquierda"><svg xmlns="http://www.w3.org/2000/svg" height="20px" viewBox="0 -960 960 960" width="20px" fill="#1f1f1f"><path d="M144-144v-72h672v72H144Zm0-150v-72h480v72H144Zm0-150v-72h672v72H144Zm0-150v-72h480v72H144Zm0-150v-72h672v72H144Z" /></svg></button>
        <button onclick="formato('justifyCenter')" title="Centrar"><svg xmlns="http://www.w3.org/2000/svg" height="20px" viewBox="0 -960 960 960" width="20px" fill="#1f1f1f"><path d="M120-120v-80h720v80H120Zm160-160v-80h400v80H280ZM120-440v-80h720v80H120Zm160-160v-80h400v80H280ZM120-760v-80h720v80H120Z" /></svg></button>
        <button onclick="formato('justifyRight')" title="Alinear derecha"><svg xmlns="http://www.w3.org/2000/svg" height="20px" viewBox="0 -960 960 960" width="20px" fill="#1f1f1f"><path d="M144-744v-72h672v72H144Zm192 150v-72h480v72H336ZM144-444v-72h672v72H144Zm192 150v-72h480v72H336ZM144-144v-72h672v72H144Z" /></svg></button>

        <div class="separador"></div>

        <button onclick="formato('insertUnorderedList')" title="Lista viñetas"><svg xmlns="http://www.w3.org/2000/svg" height="20px" viewBox="0 -960 960 960" width="20px" fill="#1f1f1f"><path d="M360-240v-72h456v72H360Zm0-204v-72h456v72H360Zm0-204v-72h456v72H360ZM215.79-204Q186-204 165-225.21t-21-51Q144-306 165.21-327t51-21Q246-348 267-326.79t21 51Q288-246 266.79-225t-51 21Zm0-204Q186-408 165-429.21t-21-51Q144-510 165.21-531t51-21Q246-552 267-530.79t21 51Q288-450 266.79-429t-51 21ZM165-633.21q-21-21.21-21-51T165.21-735q21.21-21 51-21T267-734.79q21 21.21 21 51T266.79-633q-21.21 21-51 21T165-633.21Z" /></svg></button>
        <button onclick="formato('insertOrderedList')" title="Lista numerada"><svg xmlns="http://www.w3.org/2000/svg" height="20px" viewBox="0 -960 960 960" width="20px" fill="#1f1f1f"><path d="M144-144v-48h96v-24h-48v-48h48v-24h-96v-48h120q10.2 0 17.1 6.9 6.9 6.9 6.9 17.1v48q0 10.2-6.9 17.1-6.9 6.9-17.1 6.9 10.2 0 17.1 6.9 6.9 6.9 6.9 17.1v48q0 10.2-6.9 17.1-6.9 6.9-17.1 6.9H144Zm0-240v-96q0-10.2 6.9-17.1 6.9-6.9 17.1-6.9h72v-24h-96v-48h120q10.2 0 17.1 6.9 6.9 6.9 6.9 17.1v72q0 10.2-6.9 17.1-6.9 6.9-17.1 6.9h-72v24h96v48H144Zm48-240v-144h-48v-48h96v192h-48Zm168 384v-72h456v72H360Zm0-204v-72h456v72H360Zm0-204v-72h456v72H360Z" /></svg></button>

        <div class="separador"></div>

        <button onclick="cambiarColor()" title="Color de texto"><svg xmlns="http://www.w3.org/2000/svg" id="icono-color-texto" height="20px" viewBox="0 -960 960 960" width="20px"><path d="M96 0v-192h768V0H96Zm161-336 180-480h86l180 480h-83l-43-123H384l-44 123h-83Zm151-192h144l-70-194h-4l-70 194Z" /></svg></button>
        <button onclick="insertarEnlace()" title="Insertar enlace"><svg xmlns="http://www.w3.org/2000/svg" height="20px" viewBox="0 -960 960 960" width="20px" fill="#1f1f1f"><path d="M323-143q-74 0-126-52.5T145-322q0-35 13.5-68t38.5-58l132-132 51 51-132 132q-15 15-23.5 34.5T216-322q0 45 31 75.5t76 30.5q21 0 40-8t34-23l133-132 51 51-133 132q-25 26-57.5 39.5T323-143Zm88-217-51-51 189-189 51 51-189 189Zm220-20-51-51 133-132q15-14 22.5-33.5T743-636q0-45-30.5-76T637-743q-21 0-40 7.5T563-713L431-580l-51-51 132-133q25-26 58-39t68-13q74 0 125.5 52T815-637q0 35-13 67.5T764-512L631-380Z" /></svg></button>
        <button onclick="insertarImagen()" title="Insertar imagen"><svg xmlns="http://www.w3.org/2000/svg" height="20px" viewBox="0 -960 960 960" width="20px" fill="#1f1f1f"><path d="M216-144q-29.7 0-50.85-21.5Q144-187 144-216v-528q0-29 21.15-50.5T216-816h528q29.7 0 50.85 21.5Q816-773 816-744v528q0 29-21.15 50.5T744-144H216Zm0-72h528v-528H216v528Zm48-72h432L552-480 444-336l-72-96-108 144Zm-48 72v-528 528Z" /></svg></button>
        <input type="file" id="inputImagen" accept="image/*" style="display:none" onchange="cargarImagen(this)" />
        <div class="separador"></div>

        <button onclick="formato('undo')" title="Deshacer"><svg xmlns="http://www.w3.org/2000/svg" height="20px" viewBox="0 -960 960 960" width="20px" fill="#1f1f1f"><path d="M288-192v-72h288q50 0 85-35t35-85q0-50-35-85t-85-35H330l93 93-51 51-180-180 180-180 51 51-93 93h246q80 0 136 56t56 136q0 80-56 136t-136 56H288Z" /></svg></button>
        <button onclick="formato('redo')" title="Rehacer"><svg xmlns="http://www.w3.org/2000/svg" height="20px" viewBox="0 -960 960 960" width="20px" fill="#1f1f1f"><path d="M384-192q-80 0-136-56t-56-136q0-80 56-136t136-56h246l-93-93 51-51 180 180-180 180-51-51 93-93H384q-50 0-85 35t-35 85q0 50 35 85t85 35h288v72H384Z" /></svg></button>


        <div class="separador"></div>

 
            <button class="botones-exportar btn-pdf" onclick="exportarPDF()">📄 Exportar PDF</button>
            <button class="botones-exportar btn-word" onclick="exportarWord()">📝 Exportar Word</button>

    </div>

    <div style="position:relative; padding-top:100px;">
        <!-- Contenedor de páginas -->
        <div id="contenedor-paginas"></div>
    </div>
   


    <!-- Input oculto para color -->
    <input type="color" id="colorPicker" style="display:none" onchange="aplicarColor(this.value)" />
</div>